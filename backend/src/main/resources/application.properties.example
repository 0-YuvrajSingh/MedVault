# ===================================================================
# MedVault environment example
# Copy these keys into your real .env or environment config.
# ===================================================================

# App server port
SERVER_PORT=8080

# ------------------------
# Database configuration
# ------------------------
# JDBC URL for MySQL database
DB_URL=jdbc:mysql://localhost:3306/medvault?useSSL=false&serverTimezone=UTC
# Database username
DB_USERNAME=root
# Database password
DB_PASSWORD=change_me

# ------------------------
# JPA / Hibernate settings
# ------------------------
# Schema strategy (update for local dev)
JPA_DDL_AUTO=update
# SQL logging toggle
JPA_SHOW_SQL=false
# Pretty SQL formatting
HIBERNATE_FORMAT_SQL=false

# ------------------------
# JWT configuration
# ------------------------
# 256-bit+ secret key for signing JWTs
JWT_SECRET=replace_with_a_long_random_secret_key
# Token expiration in milliseconds
JWT_EXPIRATION=86400000

# ------------------------
# Mail (SMTP) configuration
# ------------------------
# SMTP host (e.g. Gmail SMTP)
MAIL_HOST=smtp.gmail.com
# SMTP port
MAIL_PORT=587
# SMTP username/email
MAIL_USERNAME=your-email@example.com
# SMTP password or app password
MAIL_PASSWORD=your-app-password

# ------------------------
# File upload configuration
# ------------------------
# Max single file size
MAX_FILE_SIZE=10MB
# Max multipart request size
MAX_REQUEST_SIZE=10MB
# Base upload directory
FILE_UPLOAD_DIR=./uploads
# Medical records upload directory
MEDICAL_RECORDS_DIR=./uploads/medical-records
# Documents upload directory
DOCUMENTS_DIR=./uploads/documents
# Profile image upload directory
PROFILE_IMAGES_DIR=./uploads/profile-images

# ------------------------
# Logging configuration
# ------------------------
# Root logger level
LOG_LEVEL_ROOT=INFO
# Application package logger level
LOG_LEVEL_APP=DEBUG
# Log file output path
LOG_FILE=logs/medvault.log
# Console pattern
LOG_PATTERN_CONSOLE=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
