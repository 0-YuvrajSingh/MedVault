# Local Environment Variables (Not committed to version control)
# Copy this file to .env.local and update with your local values

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api

# WebSocket Configuration
VITE_WS_URL=ws://localhost:8080/ws

# Payment Gateway (Razorpay) - Use test keys for local development
VITE_RAZORPAY_KEY=rzp_test_your_test_key_here

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_PWA=false

# Service Worker
VITE_ENABLE_SERVICE_WORKER=false

# File Upload Limits (in MB)
VITE_MAX_FILE_SIZE=10
VITE_MAX_IMAGE_SIZE=5

# Pagination
VITE_DEFAULT_PAGE_SIZE=10

# Session Timeout (in minutes)
VITE_SESSION_TIMEOUT=30
